{
    "name": "purple-orca/laravel-doctor",
    "description": "High-signal health checks for Laravel apps. Run php artisan doctor to catch deploy blockers, security drift, and production footguns.",
    "type": "library",
    "keywords": ["laravel", "artisan", "health-check", "doctor", "security", "performance", "quality", "score"],
    "homepage": "https://github.com/PURPLE-ORCA/LARAVEL-DOCTOR",
    "license": "MIT",
    "authors": [
        {
            "name": "purple-orca",
            "email": "hello@purpleorca.dev"
        }
    ],
    "require": {
        "php": "^8.1",
        "laravel/framework": "^10.0|^11.0|^12.0",
        "symfony/console": "^6.0|^7.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0",
        "pestphp/pest": "^2.0"
    },
    "support": {
        "issues": "https://github.com/PURPLE-ORCA/LARAVEL-DOCTOR/issues",
        "source": "https://github.com/PURPLE-ORCA/LARAVEL-DOCTOR"
    },
    "autoload": {
        "psr-4": {
            "PurpleOrca\\Doctor\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PurpleOrca\\Doctor\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "PurpleOrca\\Doctor\\DoctorServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
